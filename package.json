{
  "name": "samengine",
  "version": "1.9.0",
  "description": "A TypeScript game library to make HTML Games",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npx samengine-build",
    "build": "tsc",
    "pack": "node scripts/clean.js && npm run build && npm pack && git push --follow-tags",
    "test": "bun test",
    "up": "npx automatic-md-index --no-h1 --files=docs/Api.md,docs/Build.md,docs/Config.md,docs/Get-Started.md,docs/README.md,CHANGELOG.md,README.md --no-strict"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./sound": "./dist/sound/index.js",
    "./utils": "./dist/utils/index.js",
    "./build": "./dist/build/index.js",
    "./physics": "./dist/physics/index.js"
  },
  "keywords": [
    "game",
    "typescript"
  ],
  "author": "Shadowdara",
  "license": "MIT",
  "devDependencies": {
    "chalk": "^5.6.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "automatic-md-index": "^1.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shadowdara/samengine"
  },
  "bugs": {
    "url": "https://github.com/shadowdara/samengine/issues"
  },
  "type": "module"
}
