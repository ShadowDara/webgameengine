{
  "name": "@shadowdara/webgameengine",
  "version": "1.4.6",
  "description": "A TypeScript game library to make HTML Games",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "pack": "node clean.js && npm run build && npm pack"
  },
  "bin": {
    "webgameengine": "dist/build/cli/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./sound": "./dist/sound/index.js",
    "./utils": "./dist/utils/index.js",
    "./build": "./dist/build/index.js",
    "./build/utils": "./dist/build/utils/index.js"
  },
  "keywords": [
    "game",
    "typescript"
  ],
  "author": "Shadowdara",
  "license": "MIT",
  "devDependencies": {
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.6.0",
    "html-minifier-terser": "^7.2.0",
    "mime": "^4.1.0",
    "ws": "^8.20.0"
  }
}
