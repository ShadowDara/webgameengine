{
  "name": "samengine-build",
  "version": "1.9.2",
  "description": "The build and export Tool for samengine.",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "pack": "node ../scripts/clean.js && npm run build && npm pack && git push --follow-tags"
  },
  "exports": {
    ".": "./dist/index.js",
    "./utils": "./dist/utils/index.js"
  },
  "bin": {
    "samengine-build": "dist/cli/cli.js"
  },
  "author": "Shadowdara",
  "type": "module",
  "devDependencies": {
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "esbuild": "^0.28.0",
    "html-minifier-terser": "^7.2.0",
    "mime": "^4.1.0",
    "samengine": "^1.7.9",
    "ws": "^8.20.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shadowdara/samengine",
    "directory": "samengine-build"
  },
  "bugs": {
    "url": "https://github.com/shadowdara/samengine/issues"
  }
}
