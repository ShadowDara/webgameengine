{
  "compilerOptions": {
    "rootDir": "engine",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Bundler",

    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["engine"],
  "exclude": ["node_modules", "**/*.test.ts", "test"],
}